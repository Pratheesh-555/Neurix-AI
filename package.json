{
  "name": "neurixai",
  "version": "1.0.0",
  "description": "Neurix AI — Clinical AI for autism therapists",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm run ml\"",
    "server": "cd server && node server.js",
    "client": "cd client && npm run dev",
    "ml": "cd ml-service && venv\\Scripts\\uvicorn.exe main:app --reload --port 8000",
    "train": "cd ml-service && python model/train.py",
    "seed": "cd server && node scripts/seedDemoChildren.js",
    "build": "cd client && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
