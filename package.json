{
  "name": "neurixai",
  "version": "1.0.0",
  "description": "Neurix AI — Clinical AI for autism therapists",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\" \"npm run ml\"",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/server.js",
    "client": "npm --prefix client run dev",
    "ml": "cd ml-service && python -m uvicorn main:app --host 0.0.0.0 --port 8000",
    "train": "cd ml-service && python model/train.py",
    "seed": "cd server && node scripts/seedDemoChildren.js",
    "build": "cd client && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
