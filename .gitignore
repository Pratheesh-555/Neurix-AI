# ─── Node ────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log

# ─── Python ──────────────────────────────────────────────────────────────────
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ─── ML artefacts (regenerate with: python model/train.py) ───────────────────
ml-service/saved/
ml-service/model/saved/
ml-service/chroma_store/
*.pkl

# ─── HuggingFace model cache ─────────────────────────────────────────────────
.cache/

# ─── Secrets — NEVER commit ──────────────────────────────────────────────────
.env
*.env
!.env.example

# ─── OS junk ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Temp files left by Claude agent ─────────────────────────────────────────
tmpclaude-*
tasks/

# ─── Business / internal docs ────────────────────────────────────────────────
*.docx
*.pdf

# ─── Datasets (all raw data — regenerate via scripts/run_ingestion.py) ────────
/dataset/
dataset/

# Extra safety — large binary / archive types anywhere in repo
*.zip
*.xlsx
*.xls
*.h5
*.hdf5
*.npy
*.npz
*.parquet

# DREAM sensor time-series JSONs are huge — ignore them individually too
DREAMdataset/
ml-service/chroma_store/

# Optical flow frames
optical_flow-001/
optical_flow_jpg/
